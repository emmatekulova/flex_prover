# Wallet
PRIVATE_KEY=<your Coston2 private key, no 0x prefix>
INITIAL_OWNER=0x<your wallet address>

# CEX API credentials are no longer stored in environment variables.
# They are passed per-request, encrypted with the TEE node's public key (ECIES),
# and decrypted inside the TEE. See CEXRequest.encryptedCredentials.

# Optional: override Binance base URLs (e.g. for testnet)
# BINANCE_SPOT_API_BASE_URL=https://testnet.binance.vision
# BINANCE_FUTURES_API_BASE_URL=https://testnet.binancefuture.com

# Set after deploying InstructionSender (step 1)
INSTRUCTION_SENDER=0x

# Set after registering extension (step 2)
EXTENSION_ID=0x

# Set after starting the tunnel (step 4)
TUNNEL_URL=https://

# Set after deploying BinanceAttestationStore (optional, skips re-deploy)
ATTESTATION_STORE=0x

# Override default fee in wei (optional)
# FEE_WEI=1000000000000000

# Logging
LOG_LEVEL=INFO
