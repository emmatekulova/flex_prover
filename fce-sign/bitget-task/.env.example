# Wallet
PRIVATE_KEY=<your Coston2 private key, no 0x prefix>
INITIAL_OWNER=0x<your wallet address>

# Binance API (required for account/profile/pnl handlers)
BINANCE_API_KEY=<your Binance API key>
BINANCE_SECRET_KEY=<your Binance secret key>

# Bitget API (required for bitget-account handler)
BITGET_API_KEY=<your Bitget API key>
BITGET_SECRET_KEY=<your Bitget secret key>
BITGET_PASSPHRASE=<your Bitget API passphrase>

# Set after deploying InstructionSender (step 1)
INSTRUCTION_SENDER=0x

# Set after registering extension (step 2)
EXTENSION_ID=0x

# Set after starting the tunnel (step 4)
TUNNEL_URL=https://

# Set after deploying BinanceAttestationStore (optional, skips re-deploy)
ATTESTATION_STORE=0x

# Override default fee in wei (optional)
# FEE_WEI=1000000000000000

# Logging
LOG_LEVEL=INFO

